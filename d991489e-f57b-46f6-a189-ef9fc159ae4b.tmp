<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MENSTRELMINT</title>
<link href="https://fonts.googleapis.com/css2?family=UnifrakturMaguntia&family=IM+Fell+English:ital@0;1&family=Share+Tech+Mono&display=swap" rel="stylesheet">

<!-- FIREBASE: sostituisci questo blocco con la tua config Firebase -->
<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
  import { getDatabase, ref, set, get, onValue, push, update, remove }
    from "https://www.gstatic.com/firebasejs/10.12.0/firebase-database.js";

  // ════════════════════════════════════════════════
  const firebaseConfig = {
    apiKey: "AIzaSyCcfNGKYt0v8swxcp0TpqU2zUGA3wpiJLE",
    authDomain: "menstrelmint-c689e.firebaseapp.com",
    databaseURL: "https://menstrelmint-c689e-default-rtdb.europe-west1.firebasedatabase.app",
    projectId: "menstrelmint-c689e",
    storageBucket: "menstrelmint-c689e.firebasestorage.app",
    messagingSenderId: "688543823587",
    appId: "1:688543823587:web:c0e222c4826438745777d6"
  };
  // ════════════════════════════════════════════════

  const app = initializeApp(firebaseConfig);
  const db = getDatabase(app);
  window._db = db;
  window._dbRef = ref;
  window._dbSet = set;
  window._dbGet = get;
  window._dbOnValue = onValue;
  window._dbPush = push;
  window._dbUpdate = update;
  window._dbRemove = remove;
  window._firebaseReady = true;
  document.dispatchEvent(new Event('firebaseReady'));
</script>

<style>
  :root {
    --bg: #080808;
    --surface: #0f0f0f;
    --surface2: #161616;
    --border: #2a2a2a;
    --text: #d4c9b8;
    --text-dim: #6b6258;
    --red: #8b0000;
    --red-bright: #c41e3a;
    --red-glow: rgba(139,0,0,0.3);
    --gold: #a08060;
    --font-title: 'UnifrakturMaguntia', serif;
    --font-body: 'IM Fell English', serif;
    --font-mono: 'Share Tech Mono', monospace;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html, body {
    width: 100%; min-height: 100vh;
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    overflow-x: hidden;
  }

  /* ── NOISE OVERLAY ── */
  body::before {
    content: '';
    position: fixed; inset: 0; z-index: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    opacity: 0.6;
  }

  /* ══════════════════════════════════════════
     LANDING SCREEN
  ══════════════════════════════════════════ */
  #screen-landing {
    position: fixed; inset: 0; z-index: 100;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    background: var(--bg);
    transition: opacity 1.2s ease, transform 1.2s ease;
  }
  #screen-landing.exit {
    opacity: 0;
    transform: scale(1.08);
    pointer-events: none;
  }

  .landing-sigil {
    width: 120px; height: 120px;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeIn 2s ease 0.5s forwards;
  }

  .band-title {
    font-family: var(--font-title);
    font-size: clamp(3rem, 10vw, 7rem);
    letter-spacing: 0.05em;
    color: var(--text);
    text-shadow: 0 0 40px var(--red-glow), 0 0 80px rgba(139,0,0,0.1);
    opacity: 0;
    animation: fadeIn 2s ease 1s forwards;
    text-align: center;
  }

  .landing-sub {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.4em;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-top: 0.8rem;
    opacity: 0;
    animation: fadeIn 2s ease 1.8s forwards;
  }

  .landing-invite {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1rem;
    color: var(--gold);
    margin-top: 3rem;
    opacity: 0;
    animation: fadeIn 2s ease 2.5s forwards;
    text-align: center;
    max-width: 400px;
    line-height: 1.8;
  }

  .enter-btn {
    margin-top: 3rem;
    padding: 0.8rem 3rem;
    background: transparent;
    border: 1px solid var(--red);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    cursor: pointer;
    opacity: 0;
    animation: fadeIn 2s ease 3.2s forwards;
    position: relative;
    transition: all 0.3s ease;
    overflow: hidden;
  }
  .enter-btn::before {
    content: '';
    position: absolute; inset: 0;
    background: var(--red);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
    z-index: -1;
  }
  .enter-btn:hover { color: #fff; border-color: var(--red-bright); }
  .enter-btn:hover::before { transform: scaleX(1); }

  .blood-line {
    width: 1px; height: 80px;
    background: linear-gradient(to bottom, transparent, var(--red), transparent);
    margin: 2rem auto 0;
    opacity: 0;
    animation: fadeIn 3s ease 2s forwards;
  }

  /* ══════════════════════════════════════════
     NICKNAME SCREEN
  ══════════════════════════════════════════ */
  #screen-nickname {
    position: fixed; inset: 0; z-index: 90;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    background: var(--bg);
    opacity: 0; pointer-events: none;
    transition: opacity 0.8s ease;
  }
  #screen-nickname.active { opacity: 1; pointer-events: all; }

  .nick-title {
    font-family: var(--font-title);
    font-size: 2.5rem;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  .nick-sub {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    color: var(--text-dim);
    margin-bottom: 2.5rem;
  }

  .nick-input {
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 1.2rem;
    letter-spacing: 0.2em;
    padding: 0.6rem 0;
    width: 260px;
    text-align: center;
    outline: none;
    transition: border-color 0.3s;
  }
  .nick-input:focus { border-color: var(--red); }
  .nick-input::placeholder { color: var(--text-dim); font-size: 0.8rem; }

  .nick-btn {
    margin-top: 2rem;
    padding: 0.7rem 2.5rem;
    background: var(--red);
    border: none;
    color: #fff;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.3s;
  }
  .nick-btn:hover { background: var(--red-bright); }

  .nick-error {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--red-bright);
    margin-top: 1rem;
    min-height: 1rem;
    letter-spacing: 0.1em;
  }

  /* ══════════════════════════════════════════
     MAIN APP
  ══════════════════════════════════════════ */
  #screen-app {
    position: relative; z-index: 1;
    min-height: 100vh;
    opacity: 0;
    transition: opacity 0.8s ease;
    padding-bottom: 4rem;
  }
  #screen-app.active { opacity: 1; }

  .app-header {
    border-bottom: 1px solid var(--border);
    padding: 1.5rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky; top: 0; z-index: 50;
    background: rgba(8,8,8,0.95);
    backdrop-filter: blur(4px);
  }
  .app-band-name {
    font-family: var(--font-title);
    font-size: 1.8rem;
    color: var(--text);
    text-shadow: 0 0 20px var(--red-glow);
  }
  .app-user {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: var(--text-dim);
  }
  .app-user span { color: var(--gold); }

  .main-tabs {
    display: flex;
    border-bottom: 1px solid var(--border);
    padding: 0 2rem;
    background: rgba(8,8,8,0.8);
  }
  .tab-btn {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--text-dim);
    background: none; border: none;
    padding: 1rem 1.5rem;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all 0.3s;
  }
  .tab-btn.active { color: var(--text); border-bottom-color: var(--red); }
  .tab-btn:hover { color: var(--text); }

  .main-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  /* ── CATEGORIES ── */
  .cat-filter {
    display: flex; flex-wrap: wrap; gap: 0.5rem;
    margin-bottom: 2rem;
  }
  .cat-chip {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.4rem 1rem;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-dim);
    cursor: pointer;
    transition: all 0.2s;
  }
  .cat-chip.active, .cat-chip:hover {
    border-color: var(--red);
    color: var(--text);
    background: rgba(139,0,0,0.08);
  }

  /* ── NEW PROPOSAL BUTTON ── */
  .new-proposal-btn {
    display: flex; align-items: center; gap: 0.8rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    padding: 0.8rem 1.5rem;
    background: transparent;
    border: 1px solid var(--red);
    color: var(--red-bright);
    cursor: pointer;
    transition: all 0.3s;
    margin-bottom: 2rem;
  }
  .new-proposal-btn:hover { background: var(--red-glow); color: #fff; }

  /* ── PROPOSAL CARDS ── */
  .proposals-grid {
    display: flex; flex-direction: column; gap: 1px;
  }

  .proposal-card {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 1.5rem;
    position: relative;
    transition: border-color 0.3s;
    animation: slideIn 0.4s ease;
  }
  .proposal-card:hover { border-color: #3a3a3a; }
  .proposal-card.promoted { border-left: 3px solid var(--red); }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .card-header {
    display: flex; align-items: flex-start;
    justify-content: space-between; gap: 1rem;
    margin-bottom: 0.8rem;
  }
  .card-rank {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--red);
    min-width: 2rem;
  }
  .card-title {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--text);
    flex: 1;
  }
  .card-cat {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    padding: 0.25rem 0.7rem;
    border: 1px solid var(--border);
    color: var(--text-dim);
  }
  .card-body {
    font-size: 0.9rem;
    color: var(--text-dim);
    line-height: 1.7;
    margin-bottom: 1rem;
    font-style: italic;
  }
  .card-meta {
    display: flex; align-items: center;
    gap: 1.5rem; flex-wrap: wrap;
  }
  .card-proposer {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-dim);
  }
  .card-proposer span { color: var(--gold); }
  .card-avg {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--red-bright);
  }
  .card-avg-label {
    font-size: 0.6rem;
    color: var(--text-dim);
    letter-spacing: 0.1em;
  }
  .card-votes-count {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-dim);
  }

  /* ── VOTE SECTION ── */
  .vote-section {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }
  .vote-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: var(--text-dim);
    margin-bottom: 0.6rem;
  }
  .vote-slider-wrap {
    display: flex; align-items: center; gap: 1rem;
  }
  .vote-slider {
    flex: 1;
    -webkit-appearance: none;
    height: 2px;
    background: var(--border);
    outline: none;
  }
  .vote-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 14px; height: 14px;
    background: var(--red);
    cursor: pointer;
    border-radius: 0;
    transition: background 0.2s;
  }
  .vote-slider::-webkit-slider-thumb:hover { background: var(--red-bright); }
  .vote-val {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--text);
    min-width: 2.5rem;
    text-align: center;
  }
  .vote-submit {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.5rem 1.2rem;
    background: transparent;
    border: 1px solid var(--red);
    color: var(--red-bright);
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .vote-submit:hover { background: var(--red); color: #fff; }
  .vote-submit:disabled {
    opacity: 0.3;
    cursor: default;
    border-color: var(--border);
    color: var(--text-dim);
  }

  .vote-done {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--gold);
    letter-spacing: 0.1em;
    padding-top: 0.2rem;
  }

  /* ── CHANGE PROPOSAL ── */
  .change-proposals-section {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px dashed var(--border);
  }
  .change-title-row {
    display: flex; align-items: center;
    justify-content: space-between;
    margin-bottom: 0.8rem;
  }
  .change-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: var(--text-dim);
    text-transform: uppercase;
  }
  .add-change-btn {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.3rem 0.8rem;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-dim);
    cursor: pointer;
    transition: all 0.2s;
  }
  .add-change-btn:hover { border-color: var(--red); color: var(--text); }

  .change-card {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-left: 2px solid var(--gold);
    padding: 1rem;
    margin-bottom: 0.5rem;
  }
  .change-card-title {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text);
    margin-bottom: 0.4rem;
  }
  .change-card-body {
    font-size: 0.85rem;
    color: var(--text-dim);
    font-style: italic;
    margin-bottom: 0.6rem;
    line-height: 1.6;
  }
  .change-card-meta {
    display: flex; gap: 1rem; align-items: center;
    flex-wrap: wrap;
  }

  /* ── PROPOSAL FORM MODAL ── */
  .modal-overlay {
    position: fixed; inset: 0; z-index: 200;
    background: rgba(0,0,0,0.85);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none;
    transition: opacity 0.3s;
    padding: 1rem;
  }
  .modal-overlay.active { opacity: 1; pointer-events: all; }

  .modal {
    background: var(--surface);
    border: 1px solid var(--border);
    border-top: 2px solid var(--red);
    width: 100%; max-width: 560px;
    max-height: 90vh;
    overflow-y: auto;
    padding: 2rem;
    transform: translateY(20px);
    transition: transform 0.3s;
  }
  .modal-overlay.active .modal { transform: translateY(0); }

  .modal-title {
    font-family: var(--font-title);
    font-size: 1.8rem;
    color: var(--text);
    margin-bottom: 1.5rem;
  }

  .form-group { margin-bottom: 1.2rem; }
  .form-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 0.5rem;
  }
  .form-input, .form-textarea, .form-select {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.95rem;
    padding: 0.7rem;
    outline: none;
    transition: border-color 0.2s;
    resize: vertical;
  }
  .form-select { cursor: pointer; }
  .form-input:focus, .form-textarea:focus, .form-select:focus {
    border-color: var(--red);
  }
  .form-select option { background: var(--surface); }

  .modal-actions {
    display: flex; gap: 1rem; margin-top: 1.5rem;
    justify-content: flex-end;
  }
  .modal-cancel {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    padding: 0.7rem 1.5rem;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-dim);
    cursor: pointer;
    transition: all 0.2s;
  }
  .modal-cancel:hover { border-color: var(--text-dim); color: var(--text); }
  .modal-submit {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    padding: 0.7rem 1.5rem;
    background: var(--red);
    border: none;
    color: #fff;
    cursor: pointer;
    transition: background 0.2s;
  }
  .modal-submit:hover { background: var(--red-bright); }

  /* ── RANKING BADGE ── */
  .rank-1 .card-rank { color: #c9a84c; font-size: 0.8rem; }
  .rank-2 .card-rank { color: #9a9a9a; }
  .rank-3 .card-rank { color: #8b5c3e; }

  /* ── STATUS BAR ── */
  .status-bar {
    position: fixed; bottom: 0; left: 0; right: 0;
    z-index: 50;
    background: rgba(8,8,8,0.95);
    border-top: 1px solid var(--border);
    padding: 0.5rem 2rem;
    display: flex; align-items: center; gap: 2rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-dim);
    letter-spacing: 0.15em;
  }
  .status-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--red);
    animation: pulse 2s ease infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* ── EMPTY STATE ── */
  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-dim);
    letter-spacing: 0.2em;
    border: 1px dashed var(--border);
  }

  /* ── SECTION HEADER ── */
  .section-header {
    display: flex; align-items: center; gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .section-title {
    font-family: var(--font-title);
    font-size: 1.6rem;
    color: var(--text);
  }
  .section-count {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-dim);
  }

  /* ── SIGIL SVG ── */
  .sigil { opacity: 0.15; }

  @keyframes fadeIn {
    to { opacity: 1; }
  }

  /* ── PROMOTION FLASH ── */
  @keyframes promoteFlash {
    0% { background: rgba(139,0,0,0.3); }
    100% { background: var(--surface); }
  }
  .just-promoted { animation: promoteFlash 1.5s ease; }

  /* ── THRESHOLD BAR ── */
  .threshold-bar {
    height: 2px;
    background: var(--border);
    margin-top: 0.6rem;
    position: relative;
  }
  .threshold-fill {
    height: 100%;
    background: linear-gradient(to right, var(--red), var(--red-bright));
    transition: width 0.5s ease;
  }
  .threshold-line {
    position: absolute;
    top: -3px; bottom: -3px;
    left: 75%;
    width: 1px;
    background: var(--gold);
    opacity: 0.5;
  }

  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); }

  /* ── TOAST NOTIFICATIONS ── */
  #toast-container {
    position: fixed; top: 1.5rem; right: 1.5rem;
    z-index: 9999; display: flex; flex-direction: column; gap: 0.5rem;
    pointer-events: none; max-width: 300px;
  }
  .toast {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--red);
    padding: 0.7rem 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    color: var(--text);
    opacity: 0;
    transform: translateX(16px);
    transition: opacity 0.3s, transform 0.3s;
  }
  .toast.show { opacity: 1; transform: translateX(0); }

  /* ── MEMBER CARDS ── */
  .member-card {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 1rem 1.5rem;
    display: flex; align-items: center;
    justify-content: space-between; gap: 1rem;
    flex-wrap: wrap;
  }
  .member-name {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--gold);
    letter-spacing: 0.15em;
    min-width: 120px;
  }
  .member-you {
    color: var(--text-dim);
    font-size: 0.55rem;
    margin-left: 0.4rem;
  }
  .member-stats {
    display: flex; gap: 1.5rem; flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-dim);
    letter-spacing: 0.1em;
  }
  .member-stat-val { color: var(--text); }

  /* ── PROFILE PANEL ── */
  #profile-panel {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 1.5rem 2rem;
    animation: slideDown 0.2s ease;
  }
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .profile-inner {
    max-width: 480px;
    display: flex; flex-direction: column; gap: 0.6rem;
  }
  .profile-row {
    display: flex; align-items: center; gap: 1rem;
    font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.12em;
  }
  .profile-label {
    color: var(--text-dim); min-width: 110px; text-transform: uppercase;
    font-size: 0.55rem; letter-spacing: 0.2em;
  }
  .profile-value { color: var(--text); }
  .profile-divider {
    height: 1px; background: var(--border); margin: 0.4rem 0;
  }
  .profile-pin {
    color: var(--gold); letter-spacing: 0.4em; font-size: 0.75rem;
    font-family: var(--font-mono); min-width: 60px;
  }
  .pin-reveal-btn {
    background: none; border: 1px solid var(--border);
    color: var(--text-dim); font-family: var(--font-mono);
    font-size: 0.5rem; letter-spacing: 0.15em;
    padding: 0.2rem 0.6rem; cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }
  .pin-reveal-btn:hover { border-color: var(--gold); color: var(--gold); }
  .profile-pin-note {
    font-family: var(--font-mono); font-size: 0.5rem;
    color: var(--text-dim); letter-spacing: 0.1em;
    margin: 0; opacity: 0.6;
  }
  .app-user {
    background: none; border: none; cursor: pointer;
  }

  /* ── PIN SCREEN EXTRA ── */
  .pin-note {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    color: var(--text-dim);
    margin-top: 0.5rem;
    text-align: center;
    max-width: 260px;
  }
</style>
</head>
<body>
<!-- ══════════════════════════════════════
     PASSWORD GATE
══════════════════════════════════════ -->
<div id="screen-password" style="position:fixed;inset:0;z-index:999;background:#080808;display:flex;flex-direction:column;align-items:center;justify-content:center;font-family:'Share Tech Mono',monospace;">
  <svg width="60" height="60" viewBox="0 0 120 120" fill="none" style="margin-bottom:2rem;opacity:0.4"><circle cx="60" cy="60" r="55" stroke="#8b0000" stroke-width="0.5"/><polygon points="60,8 112,90 8,90" fill="none" stroke="#8b0000" stroke-width="0.5"/><polygon points="60,112 8,30 112,30" fill="none" stroke="#8b0000" stroke-width="0.5"/><circle cx="60" cy="60" r="4" fill="#8b0000"/></svg>
  <p style="font-size:0.6rem;letter-spacing:0.4em;color:#6b6258;margin-bottom:2rem;text-transform:uppercase">accesso riservato</p>
  <input id="pw-input" type="password" style="background:transparent;border:none;border-bottom:1px solid #2a2a2a;color:#d4c9b8;font-family:'Share Tech Mono',monospace;font-size:1rem;letter-spacing:0.2em;padding:0.6rem 0;width:220px;text-align:center;outline:none;" placeholder="password" onkeydown="if(event.key==='Enter') checkPassword()"/>
  <p id="pw-error" style="color:#c41e3a;font-size:0.6rem;letter-spacing:0.1em;margin-top:1rem;min-height:1rem"></p>
  <button onclick="checkPassword()" style="margin-top:1.5rem;padding:0.7rem 2rem;background:transparent;border:1px solid #8b0000;color:#d4c9b8;font-family:'Share Tech Mono',monospace;font-size:0.65rem;letter-spacing:0.3em;text-transform:uppercase;cursor:pointer;">&#9658; entra</button>
</div>
<script>
function checkPassword(){
  if(document.getElementById('pw-input').value==='bastaorion'){
    document.getElementById('screen-password').style.display='none';
    sessionStorage.setItem('mnauth','1');
  } else {
    document.getElementById('pw-error').textContent='▸ accesso negato';
    document.getElementById('pw-input').value='';
  }
}
if(sessionStorage.getItem('mnauth')==='1')document.getElementById('screen-password').style.display='none';
</script>


<!-- ══════════════════════════════════════
     LANDING
══════════════════════════════════════ -->
<div id="screen-landing">
  <svg class="landing-sigil" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="60" cy="60" r="55" stroke="#8b0000" stroke-width="0.5" opacity="0.6"/>
    <circle cx="60" cy="60" r="42" stroke="#8b0000" stroke-width="0.3" opacity="0.4"/>
    <polygon points="60,8 112,90 8,90" fill="none" stroke="#8b0000" stroke-width="0.5" opacity="0.7"/>
    <polygon points="60,112 8,30 112,30" fill="none" stroke="#8b0000" stroke-width="0.5" opacity="0.5"/>
    <circle cx="60" cy="60" r="4" fill="#8b0000" opacity="0.8"/>
    <line x1="60" y1="5" x2="60" y2="115" stroke="#8b0000" stroke-width="0.3" opacity="0.3"/>
    <line x1="5" y1="60" x2="115" y2="60" stroke="#8b0000" stroke-width="0.3" opacity="0.3"/>
  </svg>

  <h1 class="band-title">Menstrelmint</h1>
  <p class="landing-sub">▴ forma. oscurità. struttura. ▴</p>

  <p class="landing-invite">
    Questo è lo spazio dove le idee vengono giudicate.<br>
    Porta ciò che è degno. Lascia il resto.
  </p>

  <div class="blood-line"></div>
  <button class="enter-btn" onclick="enterApp()">▸ entra</button>
</div>

<!-- ══════════════════════════════════════
     NICKNAME
<div id="screen-nickname">
  <h2 class="nick-title">Chi sei</h2>
  <p class="nick-sub" id="nick-sub-text">scegli un nome ∴ sarà permanente</p>
  <input type="text" class="nick-input" id="nick-input"
    placeholder="il tuo nome nella band"
    maxlength="20"
    onkeydown="if(event.key==='Enter') confirmNick()"/>
  <input type="password" class="nick-input" id="pin-input"
    placeholder="• • • •"
    maxlength="4"
    inputmode="numeric"
    style="display:none; margin-top:1rem; letter-spacing:0.6em; font-size:1.4rem;"
    onkeydown="if(event.key==='Enter') confirmPin()"/>
  <p class="pin-note" id="pin-note" style="display:none"></p>
  <p class="nick-error" id="nick-error"></p>
  <button class="nick-btn" id="nick-btn" onclick="confirmNick()">▸ conferma</button>
</div>
</div>

<!-- ══════════════════════════════════════
     MAIN APP
══════════════════════════════════════ -->
<div id="screen-app">
  <header class="app-header">
    <span class="app-band-name">Menstrelmint</span>
    <button class="app-user" onclick="toggleProfile()" title="il tuo profilo">▸ <span id="display-nick"></span> <span style="font-size:0.5rem;opacity:0.5">▾</span></button>
  </header>

  <!-- PROFILE PANEL -->
  <div id="profile-panel" style="display:none">
    <div class="profile-inner">
      <div class="profile-row">
        <span class="profile-label">nome</span>
        <span class="profile-value" id="profile-nick-display"></span>
      </div>
      <div class="profile-row">
        <span class="profile-label">membro dal</span>
        <span class="profile-value" id="profile-joined"></span>
      </div>
      <div class="profile-row">
        <span class="profile-label">proposte</span>
        <span class="profile-value" id="profile-stat-proposals">0</span>
      </div>
      <div class="profile-row">
        <span class="profile-label">modifiche</span>
        <span class="profile-value" id="profile-stat-changes">0</span>
      </div>
      <div class="profile-row">
        <span class="profile-label">voti espressi</span>
        <span class="profile-value" id="profile-stat-votes">0</span>
      </div>
      <div class="profile-divider"></div>
      <div class="profile-row">
        <span class="profile-label">PIN</span>
        <span class="profile-pin" id="profile-pin">••••</span>
        <button class="pin-reveal-btn" id="pin-reveal-btn" onclick="togglePinReveal()">mostra</button>
      </div>
      <p class="profile-pin-note">il PIN è salvato solo su questo dispositivo</p>
    </div>
  </div>

  <div class="main-tabs">
    <button class="tab-btn active" onclick="switchTab('proposals', this)">
      proposte ▸ <span id="count-proposals">0</span>
    </button>
    <button class="tab-btn" onclick="switchTab('approved', this)">
      approvate ▸ <span id="count-approved">0</span>
    </button>
    <button class="tab-btn" onclick="switchTab('members', this)">
      membri ▸ <span id="count-members">0</span>
    </button>
  </div>

  <div class="main-content">

    <!-- PROPOSALS TAB -->
    <div id="tab-proposals">
      <div class="cat-filter" id="cat-filter-proposals"></div>
      <button class="new-proposal-btn" onclick="openModal('proposal')">
        ＋ nuova proposta
      </button>
      <div class="section-header">
        <h2 class="section-title">In votazione</h2>
        <span class="section-count" id="proposals-sub"></span>
      </div>
      <div class="proposals-grid" id="proposals-list"></div>
    </div>

    <!-- APPROVED TAB -->
    <div id="tab-approved" style="display:none">
      <div class="cat-filter" id="cat-filter-approved"></div>
      <div class="section-header">
        <h2 class="section-title">Idee approvate</h2>
        <span class="section-count" id="approved-sub"></span>
      </div>
      <div class="proposals-grid" id="approved-list"></div>
    </div>

    <!-- MEMBERS TAB -->
    <div id="tab-members" style="display:none">
      <div class="section-header">
        <h2 class="section-title">Membri</h2>
        <span class="section-count" id="members-sub"></span>
      </div>
      <div class="proposals-grid" id="members-list"></div>
    </div>

  </div>
</div>

<!-- ══════════════════════════════════════
     STATUS BAR
══════════════════════════════════════ -->
<div class="status-bar" id="status-bar" style="display:none">
  <div class="status-dot"></div>
  <span id="status-members">— membri connessi</span>
  <span>soglia: 7.5 | quorum: tutti i membri</span>
  <span>Δ change: +0.5</span>
</div>

<!-- ══════════════════════════════════════
     MODALS
══════════════════════════════════════ -->

<!-- NEW PROPOSAL MODAL -->
<div class="modal-overlay" id="modal-proposal">
  <div class="modal">
    <h2 class="modal-title">Nuova proposta</h2>
    <div class="form-group">
      <label class="form-label">categoria</label>
      <select class="form-select" id="form-cat">
        <option value="riff">Riff</option>
        <option value="liriche">Idea per liriche</option>
        <option value="identità">Identità</option>
        <option value="canzone">Struttura canzone</option>
        <option value="struttura">Struttura brano</option>
        <option value="arrangiamento">Arrangiamento</option>
        <option value="altro">Altro</option>
      </select>
    </div>
    <div class="form-group">
      <label class="form-label">titolo</label>
      <input type="text" class="form-input" id="form-title" placeholder="nome dell'idea" maxlength="80"/>
    </div>
    <div class="form-group">
      <label class="form-label">descrizione</label>
      <textarea class="form-textarea" id="form-desc" rows="5"
        placeholder="descrivi l'idea in dettaglio…"></textarea>
    </div>
    <div class="modal-actions">
      <button class="modal-cancel" onclick="closeModal('modal-proposal')">annulla</button>
      <button class="modal-submit" onclick="submitProposal()">proponi ▸</button>
    </div>
  </div>
</div>

<!-- NEW CHANGE PROPOSAL MODAL -->
<div class="modal-overlay" id="modal-change">
  <div class="modal">
    <h2 class="modal-title">Proposta di modifica</h2>
    <input type="hidden" id="change-target-id"/>
    <div class="form-group">
      <label class="form-label">nuovo titolo</label>
      <input type="text" class="form-input" id="change-title" placeholder="titolo alternativo" maxlength="80"/>
    </div>
    <div class="form-group">
      <label class="form-label">descrizione modificata</label>
      <textarea class="form-textarea" id="change-desc" rows="5"
        placeholder="descrivi la versione modificata…"></textarea>
    </div>
    <div class="modal-actions">
      <button class="modal-cancel" onclick="closeModal('modal-change')">annulla</button>
      <button class="modal-submit" onclick="submitChange()">proponi modifica ▸</button>
    </div>
  </div>
</div>

<script>
// ═══════════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════════
let currentNick = localStorage.getItem('mnick') || null;
let currentTab  = 'proposals';
let activeFilter = { proposals: 'all', approved: 'all' };
let db, dbRef, dbSet, dbGet, dbOnValue, dbPush, dbUpdate, dbRemove;
let _members = {}, _proposals = {}, _approved = {};
let _lastNotifTime = Date.now();
let _pendingUsername = null;

const CATEGORIES = ['riff','liriche','identità','canzone','struttura','arrangiamento','altro'];
const CAT_LABELS = {
  riff:'Riff', liriche:'Liriche', identità:'Identità',
  canzone:'Canzone', struttura:'Struttura', arrangiamento:'Arrangiamento', altro:'Altro'
};
const THRESHOLD    = 7.5;
const CHANGE_DELTA = 0.5;
const PROPOSER_CAP = 8.5;

// ═══════════════════════════════════════════════════
// CRYPTO UTILS
// ═══════════════════════════════════════════════════
async function hashPin(pin) {
  const encoder = new TextEncoder();
  const data = encoder.encode('mnstrelmint_salt_' + pin);
  const hashBuffer = await crypto.subtle.digest('SHA-256', data);
  const hashArray = Array.from(new Uint8Array(hashBuffer));
  return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
}

function generatePin() {
  return String(Math.floor(1000 + Math.random() * 9000));
}

// ═══════════════════════════════════════════════════
// TOAST NOTIFICATIONS
// ═══════════════════════════════════════════════════
function showToast(msg, color = 'var(--red)') {
  const container = document.getElementById('toast-container');
  const el = document.createElement('div');
  el.className = 'toast';
  el.style.borderLeftColor = color;
  el.textContent = msg;
  container.appendChild(el);
  requestAnimationFrame(() => {
    requestAnimationFrame(() => el.classList.add('show'));
  });
  setTimeout(() => {
    el.classList.remove('show');
    setTimeout(() => el.remove(), 400);
  }, 3500);
}

async function pushNotif(msg, color) {
  const r = dbPush(dbRef(db, 'notifications'));
  await dbSet(r, { msg, by: currentNick, at: Date.now(), color: color || null });
  // Trim to last 30
  const snap = await dbGet(dbRef(db, 'notifications'));
  const keys = Object.keys(snap.val() || {});
  if (keys.length > 30) {
    const toDelete = keys.slice(0, keys.length - 30);
    for (const k of toDelete) await dbRemove(dbRef(db, `notifications/${k}`));
  }
}

// ═══════════════════════════════════════════════════
// FIREBASE INIT
// ═══════════════════════════════════════════════════
function initFirebase() {
  db      = window._db;
  dbRef   = window._dbRef;
  dbSet   = window._dbSet;
  dbGet   = window._dbGet;
  dbOnValue = window._dbOnValue;
  dbPush  = window._dbPush;
  dbUpdate = window._dbUpdate;
  dbRemove = window._dbRemove;
}

document.addEventListener('firebaseReady', async () => {
  initFirebase();
  if (currentNick) {
    // Verify stored hash still matches Firebase
    const storedHash = localStorage.getItem('mpin_hash');
    const snap = await dbGet(dbRef(db, `members/${currentNick}`));
    if (snap.exists()) {
      const member = snap.val();
      if (!member.pinHash || member.pinHash === storedHash) {
        startApp();
        return;
      }
    }
    // Mismatch — force re-login
    localStorage.removeItem('mnick');
    localStorage.removeItem('mpin_hash');
    currentNick = null;
  }
});

// ═══════════════════════════════════════════════════
// LANDING → NICKNAME → APP
// ═══════════════════════════════════════════════════
function enterApp() {
  const landing = document.getElementById('screen-landing');
  landing.classList.add('exit');
  setTimeout(() => {
    landing.style.display = 'none';
    if (currentNick) {
      showApp();
    } else {
      document.getElementById('screen-nickname').classList.add('active');
      document.getElementById('nick-input').focus();
    }
  }, 1200);
}

async function confirmNick() {
  const val = document.getElementById('nick-input').value.trim();
  const err = document.getElementById('nick-error');
  err.textContent = '';
  if (!val) { err.textContent = '▸ inserisci un nome'; return; }
  if (!db)  { err.textContent = '▸ firebase non connesso'; return; }

  const snap = await dbGet(dbRef(db, `members/${val}`));

  if (!snap.exists()) {
    // NEW USER — generate PIN, hash it, store
    const pin = generatePin();
    const pinHash = await hashPin(pin);
    await dbSet(dbRef(db, `members/${val}`), { joinedAt: Date.now(), pinHash });
    localStorage.setItem('mnick', val);
    localStorage.setItem('mpin_hash', pinHash);
    currentNick = val;

    cacheNewPin(pin);
    err.style.color = 'var(--gold)';
    err.textContent = `▸ benvenuto. il tuo PIN è: ${pin}  — lo trovi anche nel tuo profilo finché non chiudi la pagina.`;
    setTimeout(() => {
      err.textContent = '';
      err.style.color = '';
      document.getElementById('screen-nickname').classList.remove('active');
      showApp();
    }, 5000);

  } else {
    // EXISTING USER — ask PIN
    const member = snap.val();
    _pendingUsername = val;

    if (!member.pinHash) {
      // Legacy user with no PIN — assign one now
      const pin = generatePin();
      const pinHash = await hashPin(pin);
      await dbUpdate(dbRef(db, `members/${val}`), { pinHash });
      cacheNewPin(pin);
      err.style.color = 'var(--gold)';
      err.textContent = `▸ primo accesso con il nuovo sistema. PIN assegnato: ${pin} — lo trovi nel profilo finché non chiudi la pagina.`;
      setTimeout(async () => {
        err.textContent = '';
        err.style.color = '';
        localStorage.setItem('mnick', val);
        localStorage.setItem('mpin_hash', pinHash);
        currentNick = val;
        document.getElementById('screen-nickname').classList.remove('active');
        showApp();
      }, 5000);
      return;
    }

    // Show PIN input
    document.getElementById('nick-sub-text').textContent = 'nome riconosciuto — inserisci il tuo PIN';
    document.getElementById('nick-input').style.display = 'none';
    document.getElementById('pin-input').style.display = '';
    document.getElementById('pin-input').focus();
    const note = document.getElementById('pin-note');
    note.style.display = '';
    note.textContent = '4 cifre — assegnato alla registrazione';
    const btn = document.getElementById('nick-btn');
    btn.textContent = '▸ accedi';
    btn.onclick = confirmPin;
  }
}

async function confirmPin() {
  const entered = document.getElementById('pin-input').value.trim();
  const err = document.getElementById('nick-error');
  err.textContent = '';
  if (!entered || entered.length < 4) { err.textContent = '▸ PIN a 4 cifre'; return; }

  const snap = await dbGet(dbRef(db, `members/${_pendingUsername}`));
  if (!snap.exists()) { err.textContent = '▸ errore interno'; return; }

  const enteredHash = await hashPin(entered);
  const storedHash  = snap.val().pinHash;

  if (enteredHash !== storedHash) {
    err.textContent = '▸ PIN errato';
    document.getElementById('pin-input').value = '';
    return;
  }

  localStorage.setItem('mnick', _pendingUsername);
  localStorage.setItem('mpin_hash', enteredHash);
  currentNick = _pendingUsername;
  document.getElementById('screen-nickname').classList.remove('active');
  showApp();
}

function showApp() {
  document.getElementById('screen-app').classList.add('active');
  document.getElementById('status-bar').style.display = 'flex';
  document.getElementById('display-nick').textContent = currentNick;
  startApp();
}

// ═══════════════════════════════════════════════════
// REALTIME LISTENERS
// ═══════════════════════════════════════════════════
function startApp() {
  buildCatFilters();

  dbOnValue(dbRef(db, 'proposals'), snap => {
    _proposals = snap.val() || {};
    renderProposals(_proposals);
    renderMembers();
  });

  dbOnValue(dbRef(db, 'approved'), snap => {
    _approved = snap.val() || {};
    renderApproved(_approved);
    renderMembers();
  });

  dbOnValue(dbRef(db, 'members'), snap => {
    _members = snap.val() || {};
    const count = Object.keys(_members).length;
    document.getElementById('status-members').textContent =
      `${count} membro${count !== 1 ? 'i' : ''}`;
    renderMembers();
  });

  // Notifications listener
  _lastNotifTime = Date.now();
  dbOnValue(dbRef(db, 'notifications'), snap => {
    const data = snap.val() || {};
    Object.values(data).forEach(n => {
      if (n.at > _lastNotifTime && n.by !== currentNick) {
        showToast(n.msg, n.color || 'var(--red)');
        if (n.at > _lastNotifTime) _lastNotifTime = n.at;
      }
    });
  });
}

// ═══════════════════════════════════════════════════
// CATEGORIES FILTER
// ═══════════════════════════════════════════════════
function buildCatFilters() {
  ['proposals','approved'].forEach(tab => {
    const el = document.getElementById(`cat-filter-${tab}`);
    el.innerHTML = `<button class="cat-chip active" onclick="setFilter('${tab}','all',this)">Tutto</button>`;
    CATEGORIES.forEach(cat => {
      el.innerHTML += `<button class="cat-chip" onclick="setFilter('${tab}','${cat}',this)">${CAT_LABELS[cat]}</button>`;
    });
  });
}

function setFilter(tab, cat, btn) {
  activeFilter[tab] = cat;
  const container = document.getElementById(`cat-filter-${tab}`);
  container.querySelectorAll('.cat-chip').forEach(c => c.classList.remove('active'));
  btn.classList.add('active');
  if (tab === 'proposals') renderProposals(_proposals);
  else renderApproved(_approved);
}

// ═══════════════════════════════════════════════════
// RENDER PROPOSALS
// ═══════════════════════════════════════════════════
function computeAvg(votes) {
  const vals = Object.values(votes || {});
  if (!vals.length) return null;
  return vals.reduce((a,b) => a+b, 0) / vals.length;
}

function renderProposals(data) {
  const list = document.getElementById('proposals-list');
  let items = Object.entries(data).map(([id, p]) => ({ id, ...p }));
  const f = activeFilter.proposals;
  if (f !== 'all') items = items.filter(p => p.category === f);
  items.sort((a,b) => (computeAvg(b.votes)||0) - (computeAvg(a.votes)||0));

  document.getElementById('count-proposals').textContent = items.length;
  document.getElementById('proposals-sub').textContent =
    `${items.length} idea${items.length !== 1 ? 'e' : ''}`;

  list.innerHTML = items.length
    ? items.map((p, i) => proposalCardHTML(p, i, false)).join('')
    : `<div class="empty-state">— nessuna proposta —</div>`;
}

function renderApproved(data) {
  const list = document.getElementById('approved-list');
  let items = Object.entries(data).map(([id, p]) => ({ id, ...p }));
  const f = activeFilter.approved;
  if (f !== 'all') items = items.filter(p => p.category === f);
  items.sort((a,b) => (computeAvg(b.votes)||0) - (computeAvg(a.votes)||0));

  document.getElementById('count-approved').textContent = items.length;
  document.getElementById('approved-sub').textContent =
    `${items.length} idea${items.length !== 1 ? 'e' : ''}`;

  list.innerHTML = items.length
    ? items.map((p, i) => proposalCardHTML(p, i, true)).join('')
    : `<div class="empty-state">— nessuna idea approvata —</div>`;
}

// ═══════════════════════════════════════════════════
// RENDER MEMBERS
// ═══════════════════════════════════════════════════
function renderMembers() {
  const list = document.getElementById('members-list');
  if (!list) return;

  const stats = {};
  for (const nick of Object.keys(_members)) {
    stats[nick] = { proposals: 0, changes: 0, votes: 0 };
  }

  for (const p of Object.values(_proposals)) {
    if (stats[p.proposer] !== undefined) stats[p.proposer].proposals++;
    for (const nick of Object.keys(p.votes || {})) {
      if (stats[nick] !== undefined) stats[nick].votes++;
    }
  }
  for (const p of Object.values(_approved)) {
    if (stats[p.proposer] !== undefined) stats[p.proposer].proposals++;
    for (const nick of Object.keys(p.votes || {})) {
      if (stats[nick] !== undefined) stats[nick].votes++;
    }
    for (const c of Object.values(p.changeProposals || {})) {
      if (stats[c.proposer] !== undefined) stats[c.proposer].changes++;
      for (const nick of Object.keys(c.votes || {})) {
        if (stats[nick] !== undefined) stats[nick].votes++;
      }
    }
  }

  const sorted = Object.entries(stats).sort((a, b) => {
    const sa = a[1].proposals + a[1].changes + a[1].votes;
    const sb = b[1].proposals + b[1].changes + b[1].votes;
    return sb - sa;
  });

  const total = Object.keys(_members).length;
  document.getElementById('count-members').textContent = total;
  document.getElementById('members-sub').textContent =
    `${total} membro${total !== 1 ? 'i' : ''}`;

  list.innerHTML = sorted.map(([nick, s]) => `
    <div class="member-card">
      <span class="member-name">${esc(nick)}${nick === currentNick ? '<span class="member-you">◂ tu</span>' : ''}</span>
      <div class="member-stats">
        <span>proposte: <span class="member-stat-val">${s.proposals}</span></span>
        <span>modifiche: <span class="member-stat-val">${s.changes}</span></span>
        <span>voti: <span class="member-stat-val">${s.votes}</span></span>
      </div>
    </div>`).join('') || '<div class="empty-state">— nessun membro —</div>';
}

// ═══════════════════════════════════════════════════
// PROPOSAL CARD HTML
// ═══════════════════════════════════════════════════
function proposalCardHTML(p, rank, isApproved) {
  const avg = computeAvg(p.votes);
  const voteCount = Object.keys(p.votes || {}).length;
  const myVote = p.votes && p.votes[currentNick];
  const rankClass = rank===0?'rank-1':rank===1?'rank-2':rank===2?'rank-3':'';
  const pct = avg ? Math.min((avg/10)*100, 100) : 0;

  const voteSection   = isApproved ? '' : buildVoteSection(p, myVote);
  const changeSection = isApproved ? buildChangeSection(p) : '';

  return `
  <div class="proposal-card ${isApproved?'promoted':''} ${rankClass}" id="card-${p.id}">
    <div class="card-header">
      <span class="card-rank">${rank===0?'▴':rank===1?'▵':rank===2?'△':String(rank+1).padStart(2,'0')}</span>
      <span class="card-title">${esc(p.title)}</span>
      <span class="card-cat">${CAT_LABELS[p.category]||p.category}</span>
    </div>
    <div class="card-body">${esc(p.description)}</div>
    <div class="card-meta">
      <span class="card-proposer">da <span>${esc(p.proposer)}</span></span>
      ${avg!==null ? `<span class="card-avg">${avg.toFixed(1)}</span><span class="card-avg-label">/ 10</span>` : '<span class="card-avg-label">— nessun voto</span>'}
      <span class="card-votes-count">${voteCount} vot${voteCount!==1?'i':'o'}</span>
    </div>
    ${avg!==null ? `
    <div class="threshold-bar">
      <div class="threshold-fill" style="width:${pct}%"></div>
      <div class="threshold-line" title="soglia 7.5"></div>
    </div>` : ''}
    ${voteSection}
    ${changeSection}
  </div>`;
}

function buildVoteSection(p, myVote) {
  if (myVote !== undefined) {
    return `<div class="vote-section">
      <p class="vote-done">▸ hai votato: ${myVote}</p>
    </div>`;
  }
  const isProposer = p.proposer === currentNick;
  const max = isProposer ? PROPOSER_CAP : 10;
  const def = isProposer ? Math.min(7, PROPOSER_CAP) : 7;
  return `<div class="vote-section">
    <p class="vote-label">il tuo voto ${isProposer?'(max 8.5 — sei il proposer)':''}</p>
    <div class="vote-slider-wrap">
      <input type="range" class="vote-slider"
        id="slider-${p.id}" min="1" max="${max}" step="0.5"
        value="${def}"
        oninput="document.getElementById('val-${p.id}').textContent=this.value"/>
      <span class="vote-val" id="val-${p.id}">${def}</span>
      <button class="vote-submit" onclick="castVote('${p.id}')">vota ▸</button>
    </div>
  </div>`;
}

function buildChangeSection(p) {
  const changes = Object.entries(p.changeProposals || {}).map(([id,c]) => ({id,...c}));
  changes.sort((a,b) => (computeAvg(b.votes)||0) - (computeAvg(a.votes)||0));

  const changesHTML = changes.map(c => {
    const avg = computeAvg(c.votes);
    const myVote = c.votes && c.votes[currentNick];
    const parentAvg = computeAvg(p.votes);
    return `<div class="change-card">
      <div class="change-card-title">${esc(c.title)}</div>
      <div class="change-card-body">${esc(c.description)}</div>
      <div class="change-card-meta">
        <span class="card-proposer">da <span>${esc(c.proposer)}</span></span>
        ${avg!==null ? `<span class="card-avg">${avg.toFixed(1)}</span><span class="card-avg-label">/ 10</span>` : '<span class="card-avg-label">—</span>'}
        ${avg!==null && parentAvg!==null && avg > parentAvg+CHANGE_DELTA
          ? `<span style="color:var(--red-bright);font-family:var(--font-mono);font-size:0.6rem">▸ pronta per promozione</span>` : ''}
        ${myVote!==undefined
          ? `<span class="vote-done">▸ hai votato: ${myVote}</span>`
          : `<div class="vote-slider-wrap" style="flex:1">
              <input type="range" class="vote-slider"
                id="cslider-${p.id}-${c.id}"
                min="1" max="${c.proposer===currentNick?PROPOSER_CAP:10}"
                step="0.5" value="${c.proposer===currentNick?7:7}"
                oninput="document.getElementById('cval-${p.id}-${c.id}').textContent=this.value"/>
              <span class="vote-val" id="cval-${p.id}-${c.id}">7</span>
              <button class="vote-submit" onclick="castChangeVote('${p.id}','${c.id}')">vota</button>
            </div>`
        }
      </div>
    </div>`;
  }).join('');

  return `<div class="change-proposals-section">
    <div class="change-title-row">
      <span class="change-label">proposte di modifica (${changes.length})</span>
      <button class="add-change-btn" onclick="openChangeModal('${p.id}')">+ modifica</button>
    </div>
    ${changesHTML || '<p style="font-family:var(--font-mono);font-size:0.6rem;color:var(--text-dim)">— nessuna modifica proposta —</p>'}
  </div>`;
}

// ═══════════════════════════════════════════════════
// VOTING LOGIC
// ═══════════════════════════════════════════════════
async function castVote(proposalId) {
  const slider = document.getElementById(`slider-${proposalId}`);
  if (!slider) return;
  const score = parseFloat(slider.value);

  await dbUpdate(dbRef(db, `proposals/${proposalId}/votes`), { [currentNick]: score });
  showToast(`▸ voto registrato: ${score}`, 'var(--gold)');

  const snap = await dbGet(dbRef(db, `proposals/${proposalId}`));
  const proposal = snap.val();
  if (!proposal) return;

  const membersSnap = await dbGet(dbRef(db, 'members'));
  const memberCount = Object.keys(membersSnap.val() || {}).length;
  const votes = proposal.votes || {};
  const voteCount = Object.keys(votes).length;
  const avg = computeAvg(votes);

  if (voteCount >= memberCount && avg >= THRESHOLD) {
    await promoteProposal(proposalId, proposal);
  }
}

async function promoteProposal(id, proposal) {
  await dbSet(dbRef(db, `approved/${id}`), { ...proposal, approvedAt: Date.now() });
  await dbRemove(dbRef(db, `proposals/${id}`));
  await pushNotif(`▸ "${proposal.title}" è stata approvata`, 'var(--gold)');
  showToast(`▸ "${proposal.title}" approvata!`, 'var(--gold)');
}

async function castChangeVote(proposalId, changeId) {
  const slider = document.getElementById(`cslider-${proposalId}-${changeId}`);
  if (!slider) return;
  const score = parseFloat(slider.value);

  await dbUpdate(
    dbRef(db, `approved/${proposalId}/changeProposals/${changeId}/votes`),
    { [currentNick]: score }
  );
  showToast(`▸ voto modifica registrato: ${score}`, 'var(--gold)');

  const snap = await dbGet(dbRef(db, `approved/${proposalId}`));
  const original = snap.val();
  if (!original) return;

  const membersSnap = await dbGet(dbRef(db, 'members'));
  const memberCount = Object.keys(membersSnap.val() || {}).length;

  const changeData = original.changeProposals?.[changeId];
  if (!changeData) return;

  const changeVotes    = changeData.votes || {};
  const origVotes      = original.votes || {};
  const changeAvg      = computeAvg(changeVotes);
  const origAvg        = computeAvg(origVotes);
  const changeVoteCount = Object.keys(changeVotes).length;

  if (changeVoteCount >= memberCount && changeAvg !== null && origAvg !== null
      && changeAvg >= origAvg + CHANGE_DELTA) {
    const { changeProposals, ...rest } = original;
    await dbSet(dbRef(db, `approved/${proposalId}`), {
      ...rest,
      title: changeData.title,
      description: changeData.description,
      proposer: changeData.proposer,
      votes: changeData.votes,
      replacedAt: Date.now(),
      changeProposals: {}
    });
    await pushNotif(`▸ "${changeData.title}" ha sostituito la versione precedente`, 'var(--gold)');
  }
}

// ═══════════════════════════════════════════════════
// MODAL LOGIC
// ═══════════════════════════════════════════════════
function openModal(id) {
  document.getElementById(`modal-${id}`).classList.add('active');
}
function closeModal(id) {
  document.getElementById(id).classList.remove('active');
}
function openChangeModal(proposalId) {
  document.getElementById('change-target-id').value = proposalId;
  document.getElementById('change-title').value = '';
  document.getElementById('change-desc').value = '';
  document.getElementById('modal-change').classList.add('active');
}

async function submitProposal() {
  const cat   = document.getElementById('form-cat').value;
  const title = document.getElementById('form-title').value.trim();
  const desc  = document.getElementById('form-desc').value.trim();
  if (!title || !desc) return;

  const r = dbPush(dbRef(db, 'proposals'));
  await dbSet(r, {
    category: cat, title, description: desc,
    proposer: currentNick,
    votes: {}, changeProposals: {},
    createdAt: Date.now()
  });

  document.getElementById('form-title').value = '';
  document.getElementById('form-desc').value = '';
  closeModal('modal-proposal');
  showToast(`▸ proposta inviata: "${title}"`);
  await pushNotif(`▸ ${currentNick} ha proposto: "${title}"`);
}

async function submitChange() {
  const targetId = document.getElementById('change-target-id').value;
  const title    = document.getElementById('change-title').value.trim();
  const desc     = document.getElementById('change-desc').value.trim();
  if (!title || !desc || !targetId) return;

  const r = dbPush(dbRef(db, `approved/${targetId}/changeProposals`));
  await dbSet(r, {
    title, description: desc,
    proposer: currentNick,
    votes: {},
    createdAt: Date.now()
  });

  closeModal('modal-change');
  showToast(`▸ modifica proposta: "${title}"`);
  await pushNotif(`▸ ${currentNick} ha proposto una modifica: "${title}"`);
}

// ═══════════════════════════════════════════════════
// TABS
// ═══════════════════════════════════════════════════
function switchTab(tab, btn) {
  currentTab = tab;
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('tab-proposals').style.display = tab==='proposals' ? '' : 'none';
  document.getElementById('tab-approved').style.display  = tab==='approved'  ? '' : 'none';
  document.getElementById('tab-members').style.display   = tab==='members'   ? '' : 'none';
}

// ═══════════════════════════════════════════════════
// UTILS
// ═══════════════════════════════════════════════════
function esc(str) {
  if (!str) return '';
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
            .replace(/"/g,'&quot;').replace(/'/g,'&#039;');
}

// Close modals on overlay click
document.querySelectorAll('.modal-overlay').forEach(el => {
  el.addEventListener('click', e => {
    if (e.target === el) el.classList.remove('active');
  });
});

// ═══════════════════════════════════════════════════
// PROFILE PANEL
// ═══════════════════════════════════════════════════
let _pinRevealed = false;
let _plainPin    = null; // stored in memory only after first reveal attempt

function toggleProfile() {
  const panel = document.getElementById('profile-panel');
  const isOpen = panel.style.display !== 'none';
  panel.style.display = isOpen ? 'none' : '';
  if (!isOpen) refreshProfilePanel();
}

function refreshProfilePanel() {
  document.getElementById('profile-nick-display').textContent = currentNick;

  // Joined date
  const memberData = _members[currentNick];
  if (memberData && memberData.joinedAt) {
    const d = new Date(memberData.joinedAt);
    document.getElementById('profile-joined').textContent =
      d.toLocaleDateString('it-IT', { day:'2-digit', month:'long', year:'numeric' });
  }

  // Stats from cached data
  const stats = computeMyStats();
  document.getElementById('profile-stat-proposals').textContent = stats.proposals;
  document.getElementById('profile-stat-changes').textContent   = stats.changes;
  document.getElementById('profile-stat-votes').textContent     = stats.votes;

  // PIN — reset to hidden on every open
  _pinRevealed = false;
  document.getElementById('profile-pin').textContent = '••••';
  document.getElementById('pin-reveal-btn').textContent = 'mostra';
}

function computeMyStats() {
  const s = { proposals: 0, changes: 0, votes: 0 };
  for (const p of Object.values(_proposals)) {
    if (p.proposer === currentNick) s.proposals++;
    if (p.votes && p.votes[currentNick] !== undefined) s.votes++;
  }
  for (const p of Object.values(_approved)) {
    if (p.proposer === currentNick) s.proposals++;
    if (p.votes && p.votes[currentNick] !== undefined) s.votes++;
    for (const c of Object.values(p.changeProposals || {})) {
      if (c.proposer === currentNick) s.changes++;
      if (c.votes && c.votes[currentNick] !== undefined) s.votes++;
    }
  }
  return s;
}

async function togglePinReveal() {
  const pinEl  = document.getElementById('profile-pin');
  const btn    = document.getElementById('pin-reveal-btn');

  if (_pinRevealed) {
    pinEl.textContent = '••••';
    btn.textContent   = 'mostra';
    _pinRevealed      = false;
    return;
  }

  // Try to recover plain PIN: we only have the hash, so we need the user to
  // re-enter it once per session, OR we store it transiently in memory at login.
  if (_plainPin) {
    pinEl.textContent = _plainPin;
    btn.textContent   = 'nascondi';
    _pinRevealed      = true;
  } else {
    pinEl.textContent = '?';
    btn.textContent   = 'non disponibile';
    btn.title         = 'il PIN è stato mostrato solo alla registrazione. se lo hai perso, crea un nuovo account.';
  }
}

// Called right after successful login to cache PIN in memory (new users only)
function cacheNewPin(pin) {
  _plainPin = pin;
}
</script>
<div id="toast-container"></div>
</body>
</html>
